// --- 4. REVIEW SYSTEM ---
export const reviewsAPI = {
  // POST REVIEW
  create: async (reviewData) => {
    try {
      log('Posting review:', reviewData);
      const response = await fetch(`${API_URL}/reviews`, {
        method: 'POST',
        headers: getHeaders(),
        body: JSON.stringify(reviewData)
      });

      const data = await response.json();
      
      if (!response.ok) {
        throw new Error(data.error || "Gagal posting review");
      }

      return data;
    } catch (error) {
      logError('Post review error:', error);
      // Fallback to localStorage for development
      log('Falling back to localStorage for reviews');
      const existingReviews = safeJsonParse(localStorage.getItem('public_reviews'), []);
      const savedReview = {
        id: Date.now(),
        ...reviewData,
        location: reviewData.location || 'Verified Member', 
        date: new Date().toLocaleDateString('id-ID'),
        timestamp: new Date().toISOString()
      };
      
      const updatedReviews = [savedReview, ...existingReviews];
      localStorage.setItem('public_reviews', JSON.stringify(updatedReviews));
      
      return savedReview;
    }
  },

  // GET ALL REVIEWS
  getAll: async () => {
    try {
      const response = await fetch(`${API_URL}/reviews`);
      
      if (response.ok) {
        return await response.json();
      }
      
      // Fallback to localStorage
      throw new Error('API not available');
    } catch (error) {
      log('Using localStorage for reviews');
      return safeJsonParse(localStorage.getItem('public_reviews'), []);
    }
  },

  // GET PUBLIC REVIEWS (for homepage)
  getPublic: async () => {
    try {
      const response = await fetch(`${API_URL}/reviews/public`);
      
      if (response.ok) {
        return await response.json();
      }
      
      // Fallback
      throw new Error('API not available');
    } catch (error) {
      log('Using localStorage for public reviews');
      const allReviews = safeJsonParse(localStorage.getItem('public_reviews'), []);
      return allReviews.slice(0, 5); // Return only 5 for homepage
    }
  }
};

// --- 5. HOME DATA ---
export const fetchHomeData = async () => {
  try {
    log('Fetching home data');
    
    // Fetch data dari API dengan timeout
    const fetchWithTimeout = (url, timeout = 5000) => {
      return Promise.race([
        fetch(url).then(res => res.ok ? res.json() : []),
        new Promise((_, reject) => 
          setTimeout(() => reject(new Error('Timeout')), timeout)
        )
      ]);
    };

    const [products, treatments] = await Promise.allSettled([
      fetchWithTimeout(`${API_URL}/products`).catch(() => []),
      fetchWithTimeout(`${API_URL}/treatments`).catch(() => [])
    ]);

    // Fetch testimonials
    const testimonials = await reviewsAPI.getPublic();

    const result = {
      products: products.status === 'fulfilled' ? products.value.slice(0, 4) : [],
      treatments: treatments.status === 'fulfilled' ? treatments.value.slice(0, 6) : [],
      testimonials: testimonials
    };

    log('Home data fetched:', { 
      productsCount: result.products.length,
      treatmentsCount: result.treatments.length,
      testimonialsCount: result.testimonials.length
    });

    return result;
  } catch (error) {
    logError('Error fetching home data:', error);
    return {
      products: [],
      treatments: [],
      testimonials: safeJsonParse(localStorage.getItem('public_reviews'), []).slice(0, 3)
    };
  }
};

