export const clearAuthData = () => {
  log('Clearing auth data');
  localStorage.removeItem('token');
  localStorage.removeItem('user');
  localStorage.removeItem('user_type');
  localStorage.removeItem('login_time');
};

export const refreshAuth = async () => {
  try {
    const response = await fetch(`${API_URL}/auth/refresh`, {
      headers: getHeaders()
    });

    if (response.ok) {
      const data = await response.json();
      if (data.token) {
        localStorage.setItem('token', data.token);
        log('Token refreshed');
        return true;
      }
    }
    return false;
  } catch (error) {
    logError('Refresh auth error:', error);
    return false;
  }
};

// --- 12. GLOBAL API ERROR HANDLER ---
const handleApiError = (error, context = 'API') => {
  logError(`${context} error:`, error);
  
  // Cek jika error karena token expired atau unauthorized
  if (error.message?.includes('Token') || 
      error.message?.includes('token') || 
      error.message?.includes('authentikasi') ||
      error.message?.includes('unauthorized') ||
      error.message?.includes('Forbidden')) {
    log('ðŸ”’ Auth error detected, clearing auth data');
    clearAuthData();
    
    // Redirect to login page only if we're not already there
    if (!window.location.pathname.includes('/login')) {
      window.location.href = '/login';
    }
  }
  
  throw error;
};

