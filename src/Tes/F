// src/api/client.js
const API_URL = '/api';

// --- DEBUG MODE ---
const DEBUG_MODE = process.env.NODE_ENV === 'development';
const log = (...args) => DEBUG_MODE && console.log('ðŸ”§ API:', ...args);
const logError = (...args) => DEBUG_MODE && console.error('âŒ API Error:', ...args);

// --- 1. HELPER FUNCTIONS ---
const getHeaders = () => {
  const headers = {
    'Content-Type': 'application/json',
  };
  
  const token = localStorage.getItem('token');
  if (token) {
    headers['Authorization'] = `Bearer ${token}`;
  }
  
  log('Headers generated:', { hasToken: !!token, headers });
  return headers;
};

// Safe JSON parsing
const safeJsonParse = (str, defaultValue = null) => {
  try {
    return str ? JSON.parse(str) : defaultValue;
  } catch (error) {
    logError('JSON parse error:', error);
    return defaultValue;
  }
};

// --- 2. AUTH SYSTEM - DUAL SYSTEM ---
export const authAPI = {
  // REGISTER (HANYA UNTUK MEMBERS)
  register: async (userData) => {
    try {
      log('Register attempt:', { email: userData.email });
      const response = await fetch(`${API_URL}/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(userData)
      });

      const data = await response.json();
      log('Register response:', data);

      if (!response.ok) {
        // Handle specific error messages
        if (data.error && data.error.includes('already registered as admin')) {
          throw new Error('Email sudah terdaftar sebagai admin');
        }
        throw new Error(data.error || "Gagal mendaftar");
      }

      // Simpan token dan user data
      localStorage.setItem('token', data.token);
      if (data.user) {
        localStorage.setItem('user', JSON.stringify(data.user));
        localStorage.setItem('user_type', data.user.user_type || 'member');
        localStorage.setItem('login_time', new Date().toISOString());
      }

      log('Registration successful:', { 
        user_type: data.user?.user_type,
        email: data.user?.email 
      });

      return { 
        success: true, 
        user: data.user,
        token: data.token,
        message: data.message || 'Pendaftaran berhasil'
      };
      
    } catch (error) {
      logError('Register error:', error);
      throw new Error(error.message || "Koneksi ke server gagal!");
    }
  },

  // LOGIN - DUAL SYSTEM
  login: async (email, password) => {
    try {
      log('ðŸ” Login attempt:', { email });
      const response = await fetch(`${API_URL}/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      });

      const data = await response.json();
      log('ðŸ“¥ Login response:', data);

      if (!response.ok) {
        // Handle specific error messages from dual system
        if (data.error && data.error.includes('Password admin salah')) {
          throw new Error('Password admin salah');
        } else if (data.error && data.error.includes('Password member salah')) {
          throw new Error('Password member salah');
        } else if (data.error && data.error.includes('Email tidak terdaftar')) {
          throw new Error('Email tidak terdaftar');
        }
        throw new Error(data.error || "Email atau Password salah!");
      }

      // Simpan data ke localStorage
      localStorage.setItem('token', data.token);
      localStorage.setItem('user', JSON.stringify(data.user));
      localStorage.setItem('user_type', data.user.user_type || 'member');
      localStorage.setItem('login_time', new Date().toISOString());

      log('âœ… Login successful:', { 
        user_type: data.user.user_type,
        email: data.user.email,
        is_admin: data.user.is_admin
      });

      return { 
        success: true, 
        user: data.user,
        token: data.token,
        message: data.message || 'Login berhasil'
      };
      
    } catch (error) {
      logError('âŒ Login error:', error);
      
      // Better error messages for dual system
      if (error.message.includes('Password admin salah')) {
        throw new Error('Password admin salah');
      } else if (error.message.includes('Password member salah')) {
        throw new Error('Password member salah');
      } else if (error.message.includes('Email tidak terdaftar')) {
        throw new Error('Email tidak terdaftar');
      } else if (error.message.includes('Email already registered as admin')) {
        throw new Error('Email sudah terdaftar sebagai admin');
      }
      
      throw new Error(error.message || "Gagal terhubung ke server!");
    }
  },

  // LOGOUT
  logout: () => {
    log('ðŸ‘‹ Logout called');
    localStorage.removeItem('token');
    localStorage.removeItem('user');
    localStorage.removeItem('user_type');
    localStorage.removeItem('login_time');
    log('âœ… LocalStorage cleared');
  },

  // GET CURRENT USER PROFILE (UPDATED FOR DUAL SYSTEM)
  getProfile: async () => {
    try {
      const userType = localStorage.getItem('user_type');
      
      if (userType === 'admin') {
        // Get admin profile
        const response = await fetch(`${API_URL}/admin/profile`, {
          headers: getHeaders()
        });

        if (!response.ok) {
          throw new Error('Gagal mengambil data profile admin');
        }

        const data = await response.json();
        return data;
      } else {
        // Get member profile
        const user = getCurrentUser();
        if (!user || !user.id) {
          throw new Error('User not logged in');
        }

        const response = await fetch(`${API_URL}/members/${user.id}`, {
          headers: getHeaders()
        });

        if (!response.ok) {
          throw new Error('Gagal mengambil data profile');
        }

        return await response.json();
      }
    } catch (error) {
      logError('Get profile error:', error);
      throw error;
    }
  },

  // UPDATE PROFILE (UPDATED FOR DUAL SYSTEM)
  updateProfile: async (userData) => {
    try {
      const userType = localStorage.getItem('user_type');
      const currentUser = getCurrentUser();
      
      if (!currentUser || !currentUser.id) {
        throw new Error('User not logged in');
      }

      let response;
      if (userType === 'admin') {
        // Update admin profile (if endpoint exists)
        response = await fetch(`${API_URL}/admin/profile`, {
          method: 'PUT',
          headers: getHeaders(),
          body: JSON.stringify(userData)
        });
      } else {
        // Update member profile
        response = await fetch(`${API_URL}/members/${currentUser.id}`, {
          method: 'PUT',
          headers: getHeaders(),
          body: JSON.stringify(userData)
        });
      }

      const data = await response.json();
      
      if (!response.ok) {
        throw new Error(data.error || "Gagal update profile");
      }

      // Update localStorage jika ada data user baru
      if (data.user || data.data) {
        const updatedUser = data.user || data.data;
        localStorage.setItem('user', JSON.stringify({
          ...currentUser,
          ...updatedUser
        }));
      }

      return data;
    } catch (error) {
      logError('Update profile error:', error);
      throw error;
    }
  }
};

