app.get('/api/admin/dashboard', authenticateToken, requireAdmin, async (req, res) => {
  try {
    console.log('📊 Admin dashboard request from:', req.user.email);

    // Get all statistics
    const [
      [totalMembers],
      [newMembersToday],
      [todayAppointments],
      [totalAppointments],
      [pendingAppointments],
      [totalRevenue],
      [recentMembers],
      [recentAppointments]
    ] = await Promise.all([
      pool.query('SELECT COUNT(*) as count FROM members WHERE status = "active"'),
      pool.query('SELECT COUNT(*) as count FROM members WHERE status = "active" AND DATE(created_at) = CURDATE()'),
      pool.query('SELECT COUNT(*) as count FROM appointments WHERE DATE(date) = CURDATE()'),
      pool.query('SELECT COUNT(*) as count FROM appointments'),
      pool.query('SELECT COUNT(*) as count FROM appointments WHERE status = "pending"'),
      pool.query('SELECT SUM(amount) as total FROM appointments WHERE status = "completed" AND MONTH(date) = MONTH(CURDATE())'),
      pool.query('SELECT id, name, email, join_date, last_visit FROM members WHERE status = "active" ORDER BY created_at DESC LIMIT 10'),
      pool.query(`
        SELECT a.id, a.appointment_id, a.customer_name, a.treatment, a.therapist, 
               a.date, a.time, a.status, a.amount,
               m.email as customer_email
        FROM appointments a
        LEFT JOIN members m ON a.customer_id = m.id
        ORDER BY a.created_at DESC 
        LIMIT 10
      `)
    ]);

