// GET all members (PROTECTED)
app.get('/api/members', authenticateToken, async (req, res) => {
  try {
    // Jika user adalah admin, bisa lihat semua members
    // Jika user adalah member, hanya bisa lihat profile sendiri
    let query;
    let params = [];
    
    if (req.user.user_type === 'admin') {
      query = `
        SELECT id, name, email, phone, address, join_date, total_visits, 
               status, last_visit, created_at, updated_at,
               (SELECT COUNT(*) FROM member_history WHERE member_id = members.id) as appointment_count
        FROM members 
        ORDER BY created_at DESC
      `;
    } else {
      // Member hanya bisa lihat data sendiri
      query = `
        SELECT id, name, email, phone, address, join_date, total_visits, 
               status, last_visit, created_at, updated_at
        FROM members 
        WHERE id = ?
      `;
      params = [req.user.id];
    }
    
    const [rows] = await pool.query(query, params);
    res.json(rows);
  } catch (error) {
    console.error('Error fetching members:', error);
    res.status(500).json({ error: 'Failed to fetch members' });
  }
});

// GET single member by ID (PROTECTED)
app.get('/api/members/:id', authenticateToken, async (req, res) => {
  try {
    const { id } = req.params;
    
    // Cek permission: admin bisa akses semua, member hanya akses data sendiri
    if (req.user.user_type !== 'admin' && req.user.id !== parseInt(id)) {
      return res.status(403).json({ error: 'Forbidden: You can only access your own data' });
    }
    
    const [rows] = await pool.query('SELECT * FROM members WHERE id = ?', [id]);
    if (rows.length === 0) return res.status(404).json({ error: 'Member not found' });
    
    // Hapus password dari response
    const { password, ...memberWithoutPassword } = rows[0];
    res.json(memberWithoutPassword);
  } catch (error) {
    console.error('Error fetching member:', error);
    res.status(500).json({ error: 'Failed to fetch member' });
  }
});

// POST create new member (HANYA ADMIN)
app.post('/api/members', authenticateToken, requireAdmin, async (req, res) => {
  try {
    const { name, email, phone, address, join_date, total_visits, status, last_visit } = req.body;
    if (!name) return res.status(400).json({ error: 'Name is required' });

    const [result] = await pool.query(
      `INSERT INTO members (name, email, phone, address, join_date, total_visits, status, last_visit) 
       VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,
      [
        name.trim(),
        email?.trim() || null,
        phone || null,
        address?.trim() || null,
        join_date || new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }),
        parseInt(total_visits) || 0,
        status || 'active',
        last_visit || 'Never'
      ]
    );

    const [rows] = await pool.query('SELECT * FROM members WHERE id = ?', [result.insertId]);
    
    // Hapus password dari response
    const { password, ...memberWithoutPassword } = rows[0];
    res.status(201).json(memberWithoutPassword);
  } catch (error) {
    console.error('Error creating member:', error);
    res.status(500).json({ error: 'Failed to create member' });
  }
});

