// REGISTER (HANYA UNTUK MEMBERS)
app.post('/api/auth/register', async (req, res) => {
  try {
    console.log('Register request received:', req.body);
    
    const { name, email, password, phone, address } = req.body;
    
    // Validation
    if (!name || !email || !password) {
      return res.status(400).json({
        success: false,
        error: 'Name, email, and password are required'
      });
    }

    // Check if email exists in members
    const [existingMembers] = await pool.query(
      'SELECT id FROM members WHERE email = ?',
      [email.toLowerCase()]
    );

    if (existingMembers.length > 0) {
      return res.status(409).json({
        success: false,
        error: 'Email already registered as member'
      });
    }

    // Check if email exists in admin_users
    const [existingAdmins] = await pool.query(
      'SELECT id FROM admin_users WHERE email = ?',
      [email.toLowerCase()]
    );

    if (existingAdmins.length > 0) {
      return res.status(409).json({
        success: false,
        error: 'Email already registered as admin'
      });
    }

    // Hash password
    const salt = bcrypt.genSaltSync(10);
    const hashedPassword = bcrypt.hashSync(password, salt);
    
    // Join date
    const joinDate = new Date().toLocaleDateString('id-ID');

    // Insert user to members table
    const [result] = await pool.query(
      `INSERT INTO members (name, email, password, phone, address, join_date) 
       VALUES (?, ?, ?, ?, ?, ?)`,
      [
        name.trim(),
        email.toLowerCase().trim(),
        hashedPassword,
        phone || null,
        address || null,
        joinDate
      ]
    );

    console.log('User registered successfully with ID:', result.insertId);

    // Get the created user (without password)
    const [rows] = await pool.query(
      'SELECT id, name, email, phone, address, join_date, status, total_visits, last_visit FROM members WHERE id = ?',
      [result.insertId]
    );

    const user = rows[0] || {};
    
    // Generate JWT token
    const token = jwt.sign(
      {
        id: user.id,
        email: user.email,
        name: user.name,
        user_type: 'member'
      },
      process.env.JWT_SECRET || 'mochint_secret_key',
      { expiresIn: '24h' }
    );
    
    res.status(201).json({
      success: true,
      message: 'Registration successful',
      token: token,
      user: {
        id: user.id,
        name: user.name,
        email: user.email,
        phone: user.phone,
        address: user.address,
        join_date: user.join_date,
        status: user.status || 'active',
        total_visits: user.total_visits || 0,
        last_visit: user.last_visit || 'Never',
        user_type: 'member',
        is_admin: false
      }
    });

  } catch (error) {
    console.error('Register error:', error);
    res.status(500).json({
      success: false,
      error: 'Server error: ' + error.message
    });
  }
});

// LOGIN - DUAL SYSTEM
app.post('/api/auth/login', async (req, res) => {
  try {
    console.log('🔐 Login attempt for:', req.body.email);
    
    const { email, password } = req.body;

    // Validation
    if (!email || !password) {
      return res.status(400).json({
        success: false,
        error: 'Email dan password harus diisi'
      });
    }

    const normalizedEmail = email.toLowerCase().trim();

    // ============================================
    // 1. CEK DI TABEL ADMIN_USERS TERLEBIH DAHULU
    // ============================================
    console.log('🔍 Checking admin_users table...');
    const [adminRows] = await pool.query(
      `SELECT id, username, email, password, full_name, role, status, last_login 
       FROM admin_users 
       WHERE email = ? AND status = 'active'`,
      [normalizedEmail]
    );

    if (adminRows.length > 0) {
      const admin = adminRows[0];
      
      // Verify admin password
      const isPasswordValid = bcrypt.compareSync(password, admin.password);
      
      if (!isPasswordValid) {
        return res.status(401).json({
          success: false,
          error: 'Password admin salah'
        });
      }

      console.log('✅ Admin login successful:', admin.email);

      // Update last login
      await pool.query(
        'UPDATE admin_users SET last_login = NOW() WHERE id = ?',
        [admin.id]
      );

      // Generate JWT token
      const token = jwt.sign(
        {
          id: admin.id,
          email: admin.email,
          username: admin.username,
          role: admin.role,
          user_type: 'admin',
          is_admin: true
        },
        process.env.JWT_SECRET || 'mochint_secret_key',
        { expiresIn: '24h' }
      );

      // Prepare admin response
      const adminData = {
        id: admin.id,
        username: admin.username,
        email: admin.email,
        full_name: admin.full_name,
        role: admin.role,
        user_type: 'admin',
        is_admin: true,
        last_login: admin.last_login || new Date().toISOString()
      };

      return res.json({
        success: true,
        message: 'Login admin berhasil',
        token: token,
        user: adminData
      });
    }

    // ============================================
    // 2. CEK DI TABEL MEMBERS (REGULAR USERS)
    // ============================================
    console.log('🔍 Checking members table...');
    const [memberRows] = await pool.query(
      `SELECT id, name, email, password, phone, address, join_date, 
              total_visits, status, last_visit, created_at
       FROM members 
       WHERE email = ? AND status = 'active'`,
      [normalizedEmail]
    );

    if (memberRows.length > 0) {
      const member = memberRows[0];
      
      // Verify member password
      const isPasswordValid = bcrypt.compareSync(password, member.password);
      
      if (!isPasswordValid) {
        return res.status(401).json({
          success: false,
          error: 'Password member salah'
        });
      }

      console.log('✅ Member login successful:', member.email);

      // Update last visit
      await pool.query(
        'UPDATE members SET last_visit = NOW(), total_visits = total_visits + 1 WHERE id = ?',
        [member.id]
      );

      // Generate JWT token
      const token = jwt.sign(
        {
          id: member.id,
          email: member.email,
          name: member.name,
          user_type: 'member',
          is_admin: false
        },
        process.env.JWT_SECRET || 'mochint_secret_key',
        { expiresIn: '24h' }
      );

      // Prepare member response
      const memberData = {
        id: member.id,
        name: member.name,
        email: member.email,
        phone: member.phone || '',
        address: member.address || '',
        join_date: member.join_date || '',
        total_visits: (member.total_visits || 0) + 1,
        status: member.status || 'active',
        last_visit: new Date().toISOString(),
        user_type: 'member',
        is_admin: false
      };

      return res.json({
        success: true,
        message: 'Login member berhasil',
        token: token,
        user: memberData
      });
    }

    // ============================================
    // 3. USER TIDAK DITEMUKAN DI KEDUA TABEL
    // ============================================
    console.log('❌ Email not found in both tables:', normalizedEmail);
    return res.status(404).json({
      success: false,
      error: 'Email tidak terdaftar'
    });

  } catch (error) {
    console.error('❌ Login error:', error);
    res.status(500).json({
      success: false,
      error: 'Server error: ' + error.message
    });
  }
});

